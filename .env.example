# ─────────────────────────────────────────────────────────────────────────────
# Climate Risk Quantification — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Copernicus Climate Data Store (ERA5) ──────────────────────────────────────
# Register at: https://cds.climate.copernicus.eu/
# Find your key at: https://cds.climate.copernicus.eu/user/<your-id>
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=your-uid:your-api-key-here

# ── Project paths (override defaults if needed) ──────────────────────────────
DATA_RAW_DIR=data/raw
DATA_INTERIM_DIR=data/interim
DATA_PROCESSED_DIR=data/processed
MLFLOW_TRACKING_URI=mlruns

# ── Model configuration ───────────────────────────────────────────────────────
# Haircut coefficient alpha: risk-adjusted value = book_value * (1 - alpha * score)
# Range: 0.0 (no haircut) to 1.0 (full haircut at max score)
RISK_HAIRCUT_ALPHA=0.30

# Hazard weights for composite score (must sum to 1.0)
WEIGHT_FLOOD=0.40
WEIGHT_HEAT=0.35
WEIGHT_CYCLONE=0.25

# ERA5 variables to download (comma-separated internal names)
# Options: 2m_temperature, total_precipitation, 10m_wind_speed
ERA5_VARIABLES=2m_temperature,total_precipitation,10m_wind_speed

# ERA5 historical range
ERA5_YEAR_START=1990
ERA5_YEAR_END=2023

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Streamlit (optional, for local dev) ──────────────────────────────────────
# Set to 0 to disable Streamlit's usage telemetry
STREAMLIT_TELEMETRY=0
