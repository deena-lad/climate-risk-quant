# Version control
.git
.gitignore
.github

# Python cache
__pycache__
*.py[cod]
*.egg-info
.eggs
dist
build
.venv
venv
*.egg

# Local data (ERA5 files can be hundreds of MB)
data/raw/
data/interim/
data/processed/

# MLflow local store
mlruns/

# Dev / test files
tests/
notebooks/
*.ipynb
.ipynb_checkpoints

# Environment files (secrets must NEVER be baked into the image)
.env
.env.*
!.env.example

# Editor / OS artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Docs (not needed at runtime)
DEPLOY.md
SETUP.md
README_HF_HEADER.md
docs/

# Coverage / test artifacts
.coverage
coverage.xml
htmlcov/
.pytest_cache/
